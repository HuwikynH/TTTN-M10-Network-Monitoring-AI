# Local backend configuration
APP_ENV=development
DATABASE_URL=sqlite:///./network_monitoring.db
CORS_ORIGINS=http://localhost:5173

# Rule-based alert thresholds
LATENCY_WARNING_MS=100
PACKET_LOSS_WARNING_PERCENT=20
CPU_WARNING_PERCENT=90
MEMORY_WARNING_PERCENT=90

# PostgreSQL example (used instead of SQLite when needed)
# DATABASE_URL=postgresql+psycopg://monitoring:monitoring@localhost:5432/network_monitoring
