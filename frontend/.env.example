# Use local mock data for a standalone frontend demo (true/false)
VITE_USE_MOCK_DATA=false

# FastAPI base URL used by the dashboard when mock mode is disabled
VITE_API_URL=http://127.0.0.1:8000/api/v1

# REST polling interval. Values below 3000 ms fall back to 5000 ms.
VITE_REFRESH_INTERVAL_MS=5000
